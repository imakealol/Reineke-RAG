# =============================================================================
# Reineke-RAG · Konfigurations-Vorlage
# =============================================================================
#
# So gehst du vor:
#   1) Diese Datei nach `.env` kopieren:    cp .env.example .env
#   2) Jeden Block durchgehen und ANPASSEN, wo "→ ANPASSEN" steht.
#   3) Werte ohne "→ ANPASSEN" können in der Regel auf den Defaults bleiben.
#
# Hinweise zur Schreibweise:
#   - Keine Anführungszeichen um die Werte (Docker liest die Zeilen direkt).
#   - Keine Leerzeichen rund ums Gleichheitszeichen.
#   - Kommentare mit # am Zeilenanfang.
#
# =============================================================================


# -----------------------------------------------------------------------------
# 1) DOKUMENTEN-PFADE   ← der wichtigste Wert, hier MUSS angepasst werden
# -----------------------------------------------------------------------------
#
# Komma-separierte Liste absoluter Pfade auf dem HOST (nicht im Container).
# Aus Sicherheitsgründen darf das System NUR Dokumente lesen, die unter
# einem dieser Pfade liegen. Alles andere wird vom Pfad-Allow-Filter blockiert.
#
# Diese Pfade werden vom Installer automatisch read-only in den Container
# gemountet — du musst nichts in `docker-compose.yml` ändern.
#
# Beispiele:
#   ALLOWED_BASE_PATHS=/srv/dokumente
#   ALLOWED_BASE_PATHS=/mnt/dms,/srv/handbuecher,/srv/projekte
#
# → ANPASSEN:
ALLOWED_BASE_PATHS=/srv/dokumente


# -----------------------------------------------------------------------------
# 2) KI-MODELLE   ← bei Standard-Hardware auf Defaults belassen
# -----------------------------------------------------------------------------
#
# Embedding-Modell (rechnet Dokumente in Vektoren um):
#   - mxbai-embed-large    → 670 MB, schnell, 1024 Dimensionen   (Default)
#   - bge-m3               → 2.3 GB, mehrsprachig, 1024 Dim.     (empfohlen DACH)
#
# Chat-Modell (beantwortet die Fragen):
#   - qwen2.5:7b                          →   4 GB,  CPU-tauglich
#   - qwen2.5:14b                         →   9 GB,  GPU empfohlen     (Default)
#   - qwen2.5:32b-instruct-q4_K_M         →  20 GB,  ≥ 24 GB VRAM      (beste Qualität)
#   - llama3.1:8b                         →   5 GB,  Alternative
#
# Bei Apple-Silicon-Hosts (Mac mini M4) sind alle Größen praktikabel.
#
EMBEDDING_MODEL=mxbai-embed-large
CHAT_MODEL=qwen2.5:14b


# -----------------------------------------------------------------------------
# 3) SERVICES   ← nur ändern, wenn Qdrant/Ollama extern laufen
# -----------------------------------------------------------------------------
#
# Standard: Qdrant und Ollama laufen als Container neben dem Backend
# (siehe docker-compose.yml). Die Adressen unten zeigen aus dem Backend-
# Container heraus auf die Nachbar-Container.
#
# Externe Installation (z. B. Ollama nativ auf Apple-Silicon):
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
#
OLLAMA_BASE_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333

# API-Key für Qdrant — leer lassen, wenn Qdrant lokal ohne Auth läuft.
# Nur setzen, wenn der Kunde einen externen, gesicherten Qdrant betreibt.
QDRANT_API_KEY=

# Name der Qdrant-Collection — kann meist auf dem Default bleiben.
# Bei Mehr-Mandanten-Setups je Mandant einen eigenen Namen vergeben:
#   QDRANT_COLLECTION=kunde_a_dokumente
QDRANT_COLLECTION=documents


# -----------------------------------------------------------------------------
# 4) DATENBANK   ← nicht ändern (Pfad ist im Container fest)
# -----------------------------------------------------------------------------
#
# SQLite-Datei für Metadaten, Audit-Log und Chat-Verlauf.
# Wird vom Installer als persistentes Volume eingebunden
# (`/opt/reineke-rag/storage/rag.sqlite` auf dem Host).
SQLITE_DB_PATH=/app/storage/rag.sqlite


# -----------------------------------------------------------------------------
# 5) CHUNKING   ← Tuning-Parameter, Defaults sind gut für Office-Dokumente
# -----------------------------------------------------------------------------
#
# Wie groß ein Text-Chunk ist (in Zeichen) und wie stark sich Chunks überlappen.
# Größere Chunks = mehr Kontext, aber weniger präzise Treffer.
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Spreadsheet-spezifisch: wieviele Zeilen pro Chunk und maximaler Zeichen-Cap
# (schützt vor sehr breiten Tabellen, die das Embedder-Limit sprengen würden).
XLSX_ROWS_PER_CHUNK=40
XLSX_MAX_CHARS_PER_CHUNK=6000


# -----------------------------------------------------------------------------
# 6) RETRIEVAL & GENERIERUNG   ← Tuning, später feinjustierbar
# -----------------------------------------------------------------------------
#
# TOP_K = wieviele Chunks dem LLM als Kontext gegeben werden.
# 8 ist ein guter Default; bei kurzen Antworten reichen 4–6, bei
# „fasse XY zusammen"-Fragen helfen 10–12.
RETRIEVAL_TOP_K=8

# Mindest-Score (0..1). Treffer darunter werden als irrelevant verworfen.
# 0.35 ist konservativ — Halluzinationen werden so weitgehend vermieden.
MIN_RETRIEVAL_SCORE=0.35

# Temperatur des Chat-Modells. 0.1 = sehr deterministisch, gut für Wissens­fragen.
# Höhere Werte (0.5–0.8) machen Antworten kreativer, sind hier aber unerwünscht.
CHAT_TEMPERATURE=0.1

# Maximale Antwort-Länge in Tokens.
CHAT_MAX_TOKENS=1024


# -----------------------------------------------------------------------------
# 7) LIBREOFFICE   ← nur relevant für Legacy-Formate (.doc, .xls)
# -----------------------------------------------------------------------------
#
# LibreOffice steckt im Backend-Image und konvertiert .doc → .docx
# bzw. .xls → .xlsx vor der eigentlichen Verarbeitung.
# Der Pfad zur Binary ist im Container fix; nicht ändern.
SOFFICE_BIN=soffice


# -----------------------------------------------------------------------------
# 8) SERVER   ← nur ändern, wenn Port 8000 belegt ist
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Log-Level: DEBUG | INFO | WARNING | ERROR
# Während der Inbetriebnahme DEBUG hilfreich, im Betrieb auf INFO drehen.
LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# 9) GPU-FLAG   ← optional, vom Installer ausgewertet
# -----------------------------------------------------------------------------
#
# 1 = NVIDIA-GPU im Ollama-Container freigeben (benötigt nvidia-container-toolkit).
# 0 = reiner CPU-Betrieb (langsamer, aber funktioniert überall).
USE_GPU=0


# -----------------------------------------------------------------------------
# 10) BACKUP   ← Aufbewahrungsdauer für nächtliche Snapshots
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=14


# =============================================================================
# Optional / zukünftig — derzeit NICHT vom Backend ausgewertet
# =============================================================================
# Diese Werte sind Platzhalter für kommende Versionen (OIDC-SSO, Mehr-Mandanten-
# Trennung auf API-Ebene). Sie können vorbereitend gesetzt, müssen aber bei der
# aktuellen Version NICHT ausgefüllt werden.
#
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=
# TENANT_ID=default
# ADMIN_EMAIL=admin@example.com
