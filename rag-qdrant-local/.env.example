# =============================================================================
# Reineke-RAG / rag-qdrant-local — example configuration
# Copy this file to `.env` and adjust the values for your environment.
# =============================================================================

# Ollama (assumed running)
OLLAMA_BASE_URL=http://localhost:11434
# Optional clamp for the chat model's context window. Leave empty to
# auto-detect from /api/show (use the model's full declared max — typically
# 32k for qwen2.5). Set explicitly on RAM-constrained boxes where the
# full KV cache would push the host into OOM, e.g. OLLAMA_NUM_CTX=8192.
OLLAMA_NUM_CTX=

# Qdrant (assumed running)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Models
EMBEDDING_MODEL=mxbai-embed-large
CHAT_MODEL=qwen2.5:14b

# Allowed source paths — comma-separated, absolute paths only.
# The user can only ingest files that physically reside under one of these.
ALLOWED_BASE_PATHS=/mnt/rag-data,/srv/customer-files

# SQLite metadata store
SQLITE_DB_PATH=./storage/rag.sqlite

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Spreadsheet chunking (rows per chunk)
XLSX_ROWS_PER_CHUNK=40
# Hard character cap per spreadsheet chunk — protects against very wide
# tables overflowing the embedder's context window.
XLSX_MAX_CHARS_PER_CHUNK=6000

# Retrieval
# TOP_K=8 gives the LLM more chunks to work with — improves recall on broad
# "fasse XY zusammen" / "welche Konsequenzen…" questions without hurting
# precision (irrelevant chunks are filtered by MIN_RETRIEVAL_SCORE anyway).
RETRIEVAL_TOP_K=8
MIN_RETRIEVAL_SCORE=0.35

# Generation
CHAT_TEMPERATURE=0.1
CHAT_MAX_TOKENS=1024

# Query rewriter — resolves pronoun follow-ups ("welche von beiden ist
# strenger?") before the embed call so retrieval doesn't have to guess
# from six bare words. Adds one LLM call per follow-up turn.
# Set to false to disable wholesale (e.g. when latency is critical).
ENABLE_QUERY_REWRITE=true
# Model used for the rewrite step. Empty = reuse CHAT_MODEL (no extra
# RAM, slowest rewrite). Set to a smaller model on hardware that can
# keep both warm — qwen2.5:7b cuts the rewrite to ~0.5-1.5s, qwen2.5:3b
# to ~0.2-0.5s. Remember to `ollama pull <model>` first.
REWRITE_MODEL=

# LibreOffice (optional, only required for legacy .doc / .xls)
SOFFICE_BIN=soffice

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
