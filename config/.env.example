# ------------------------------------------------------------
# Reineke-RAG — environment template
# Copy to .env and fill in / let scripts/bootstrap.sh generate
# NEVER commit .env
# ------------------------------------------------------------

## Host + paths ----------------------------------------------------
TZ=Europe/Berlin
PRIMARY_DOMAIN=rag.reineke.local
DATA_ROOT=/var/lib/reineke
CONFIG_ROOT=/etc/reineke
BACKUP_ROOT=/Volumes/Backup/reineke

## Admin bootstrap -------------------------------------------------
ADMIN_EMAIL=admin@reineke-technik.de
AUTHENTIK_BOOTSTRAP_PASSWORD=                      # generated by bootstrap.sh; first-login change required
AUTHENTIK_BOOTSTRAP_TOKEN=                         # random, ≥ 60 chars

## Secrets (generated by scripts/bootstrap.sh if missing) ----------
AUTHENTIK_SECRET_KEY=
AUTHENTIK_DB_PASSWORD=
POSTGRES_PASSWORD=
LANGFUSE_DB_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
QDRANT_API_KEY=
MINIO_ROOT_USER=rag
MINIO_ROOT_PASSWORD=
INTERNAL_SERVICE_TOKEN=                             # shared between our FastAPIs

## OIDC clients (created by Authentik blueprint; IDs + secrets generated on apply) --
OIDC_CLIENT_ID_OPENWEBUI=
OIDC_CLIENT_SECRET_OPENWEBUI=
OIDC_CLIENT_ID_LANGFUSE=
OIDC_CLIENT_SECRET_LANGFUSE=
OIDC_CLIENT_ID_GRAFANA=
OIDC_CLIENT_SECRET_GRAFANA=
OIDC_CLIENT_ID_RETRIEVAL=
OIDC_CLIENT_SECRET_RETRIEVAL=
OIDC_CLIENT_ID_INGESTION=
OIDC_CLIENT_SECRET_INGESTION=
OIDC_CLIENT_ID_DUCKDB=
OIDC_CLIENT_SECRET_DUCKDB=
OIDC_CLIENT_ID_N8N=
OIDC_CLIENT_SECRET_N8N=

## Models (ADR-003, ADR-004, ADR-010) ----------------------------
EMBED_MODEL=bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3

LLM_FAST=gemma2:9b-instruct-q5_K_M
LLM_REASONING=qwen2.5:32b-instruct-q4_K_M
LLM_HEAVY=qwen2.5:32b-instruct-q4_K_M               # default = same as reasoning on Mac; see LLM_PROFILE
# Set LLM_HEAVY=llama3.3:70b-instruct-q4_K_M when LLM_PROFILE=heavy-70b

LLM_PROFILE=default
# default    = Fast + Reasoning + (Heavy = Reasoning). macOS default.
# compact    = Fast + Reasoning only; synthesis routed to Reasoning.
# heavy-70b  = Fast + Reasoning + (Heavy = Llama 3.3 70B). Explicit opt-in; slow on M4 Max.

## Ollama runtime (ADR-010) --------------------------------------
OLLAMA_MODE=native                                  # native | docker | external
OLLAMA_URL=http://host.docker.internal:11434        # native on macOS
# OLLAMA_URL=http://ollama:11434                    # when running with profile ollama-docker
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=10m

## Reranker runtime (ADR-010) ------------------------------------
RERANK_MODE=sentence-transformers                   # sentence-transformers | tei
RERANK_URL=http://reranker:8090                     # for sentence-transformers profile
# RERANK_URL=http://tei-reranker:8080               # when RERANK_MODE=tei

## Retrieval knobs (02_ARCHITECTURE §7.3 + ADR-009) --------------
TOP_K_DENSE=50
TOP_K_SPARSE=50
TOP_K_RERANK=12
HYBRID_FUSION=rrf                                   # or dbsf
QUERY_REWRITE=true                                  # multi-doc only; auto-off on single-doc paths
CITATION_STYLE=brackets                             # brackets|footnotes
REFUSAL_ON_EMPTY=true                               # never fabricate

# Single-doc pathway (ADR-009)
FULL_DOC_CONTEXT_THRESHOLD=20480                    # tokens; single-doc extract/summarize uses full-doc context below this
SCOPE_MIN_CONFIDENCE=0.5                            # deterministic scope extractor threshold
SCOPE_INHERIT_TURNS=3                               # look back N turns for doc_id inheritance

## Ingestion knobs (ADR-001) --------------------------------------
CHUNK_MAX_TOKENS=512
CHUNK_MIN_TOKENS=128
PRESERVE_TABLES=true
OCR_LANG=deu+eng                                    # Tesseract trained data when PARSER_FALLBACK=tesseract
PARSER_FALLBACK=pymupdf                             # used only on Docling hard-failures
PDF_UNLOCK_ATTEMPTS=false                           # try empty-password unlock on encrypted PDFs

## ACLs ------------------------------------------------------------
DEFAULT_FOLDER_ACL=admin

## Automation (profile: automation) -------------------------------
WATCH_ROOT=/Volumes/Docs

## Backup ---------------------------------------------------------
BACKUP_GPG_PASSPHRASE_FILE=                         # if encrypted backups wanted

## Alerts ---------------------------------------------------------
ALERT_WEBHOOK_URL=                                  # optional Teams/Slack webhook
